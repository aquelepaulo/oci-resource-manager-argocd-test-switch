apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: test-switch
  namespace: argocd
spec:
  project: default
  source:
    repoURL: __GIT_REPOSITORY_URL__
    targetRevision: main
    path: kubernetes/app
  destination:
    server: https://kubernetes.default.svc
    namespace: gitops-demo
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
